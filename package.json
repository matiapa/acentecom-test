{
  "name": "shopify-supabase-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "RUN_DB_TESTS=1 vitest run --no-file-parallelism int.test",
    "migrate": "tsx src/cli/migrate.ts",
    "sync": "tsx src/cli/sync.ts",
    "report": "tsx src/cli/report.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
